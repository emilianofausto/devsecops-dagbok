{
    "info": {
        "_postman_id": "a1b2c3d4-e5f6-7a8b-9c0d-1e2f3a4b5c6d",
        "name": "DevSecOps Diary API Tests",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. Create Valid Entry",
            "request": {
                "method": "POST",
                "header": [
                    { "key": "Content-Type", "value": "application/json" },
                    { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"title\": \"Postman Test Entry\",\n    \"content\": \"Automated API validation payload\",\n    \"category\": \"DevSecOps\"\n}"
                },
                "url": {
                    "raw": "http://127.0.0.1:8000/api/entries",
                    "protocol": "http",
                    "host": ["127", "0", "0", "1"],
                    "port": "8000",
                    "path": ["api", "entries"]
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 201\", function () { pm.response.to.have.status(201); });",
                            "pm.test(\"Response has an ID\", function () { var jsonData = pm.response.json(); pm.collectionVariables.set(\"last_entry_id\", jsonData.id); });"
                        ],
                        "type": "text/javascript"
                    }
                }
            ]
        },
        {
            "name": "2. Create Invalid Entry (Validation Test)",
            "request": {
                "method": "POST",
                "header": [
                    { "key": "Content-Type", "value": "application/json" },
                    { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"title\": \"\",\n    \"content\": \"Missing required fields\",\n    \"category\": \"\"\n}"
                },
                "url": {
                    "raw": "http://127.0.0.1:8000/api/entries",
                    "protocol": "http",
                    "host": ["127", "0", "0", "1"],
                    "port": "8000",
                    "path": ["api", "entries"]
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": { "exec": ["pm.test(\"Status code is 422\", function () { pm.response.to.have.status(422); });"], "type": "text/javascript" }
                }
            ]
        },
        {
            "name": "3. Get All Entries",
            "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": {
                    "raw": "http://127.0.0.1:8000/api/entries",
                    "protocol": "http",
                    "host": ["127", "0", "0", "1"],
                    "port": "8000",
                    "path": ["api", "entries"]
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": { "exec": ["pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });", "pm.test(\"Is array\", function () { pm.expect(pm.response.json()).to.be.an('array'); });"], "type": "text/javascript" }
                }
            ]
        },
        {
            "name": "4. Get Single Created Entry",
            "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": {
                    "raw": "http://127.0.0.1:8000/api/entries/{{last_entry_id}}",
                    "protocol": "http",
                    "host": ["127", "0", "0", "1"],
                    "port": "8000",
                    "path": ["api", "entries", "{{last_entry_id}}"]
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": { "exec": ["pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });"], "type": "text/javascript" }
                }
            ]
        },
        {
            "name": "5. Get Non-Existent Entry",
            "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": {
                    "raw": "http://127.0.0.1:8000/api/entries/99999",
                    "protocol": "http",
                    "host": ["127", "0", "0", "1"],
                    "port": "8000",
                    "path": ["api", "entries", "99999"]
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": { "exec": ["pm.test(\"Status code is 404\", function () { pm.response.to.have.status(404); });"], "type": "text/javascript" }
                }
            ]
        },
        {
            "name": "6. Update Existing Entry",
            "request": {
                "method": "PUT",
                "header": [
                    { "key": "Content-Type", "value": "application/json" },
                    { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "body": { "mode": "raw", "raw": "{\n    \"title\": \"Updated Postman Title\"\n}" },
                "url": {
                    "raw": "http://127.0.0.1:8000/api/entries/{{last_entry_id}}",
                    "protocol": "http",
                    "host": ["127", "0", "0", "1"],
                    "port": "8000",
                    "path": ["api", "entries", "{{last_entry_id}}"]
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": { "exec": ["pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });"], "type": "text/javascript" }
                }
            ]
        },
        {
            "name": "7. Delete Entry",
            "request": {
                "method": "DELETE",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": {
                    "raw": "http://127.0.0.1:8000/api/entries/{{last_entry_id}}",
                    "protocol": "http",
                    "host": ["127", "0", "0", "1"],
                    "port": "8000",
                    "path": ["api", "entries", "{{last_entry_id}}"]
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": { "exec": ["pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });"], "type": "text/javascript" }
                }
            ]
        }
    ],
